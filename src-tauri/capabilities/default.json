{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "fs:allow-watch",
    "http:default",
    "store:default",
    "clipboard:default",
    "dialog:default",
    "mcp-bridge:default",
    "core:menu:default",
    "core:menu:allow-new",
    "core:menu:allow-popup",
    "core:menu:allow-set-text",
    "core:menu:allow-set-enabled"
  ]
}
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prototyper",
  "version": "0.1.3",
  "identifier": "com.m.prototyper",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prototyper",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*", "$APPCACHE/**/*", "$RESOURCE/**/*"]
      },
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' http://localhost:* https://api.openai.com https://api.anthropic.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

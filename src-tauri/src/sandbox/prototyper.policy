"""
Prototyper execution policy for agcodex-execpolicy.
Allows safe development tools commonly used in UI prototyping.
Note: define_program, flag, opt, ARG_* are built-in globals — no load() needed.
"""

define_program(
    program="ls",
    system_path=["/usr/bin/ls", "/bin/ls"],
    options=[
        flag("-l"),
        flag("-a"),
        flag("-A"),
        flag("-h"),
        flag("-1"),
        flag("--long"),
        flag("--all"),
        flag("--human-readable"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="cat",
    system_path=["/usr/bin/cat", "/bin/cat"],
    options=[
        flag("-n"),
        flag("-b"),
        flag("-s"),
        flag("-T"),
        flag("-v"),
        flag("-e"),
        flag("-A"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="head",
    system_path=["/usr/bin/head", "/bin/head"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="wc",
    system_path=["/usr/bin/wc", "/bin/wc"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="tail",
    system_path=["/usr/bin/tail", "/bin/tail"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="sort",
    system_path=["/usr/bin/sort", "/bin/sort"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="uniq",
    system_path=["/usr/bin/uniq", "/bin/uniq"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="du",
    system_path=["/usr/bin/du", "/bin/du"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="file",
    system_path=["/usr/bin/file", "/bin/file"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="stat",
    system_path=["/usr/bin/stat", "/bin/stat"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="tree",
    system_path=["/usr/bin/tree", "/bin/tree"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="find",
    system_path=["/usr/bin/find", "/bin/find"],
    options=[
        flag("-H"), flag("-L"), flag("-P"),
        flag("-not"), flag("-and"), flag("-or"),
        flag("-path"), flag("-name"), flag("-iname"),
        flag("-type"), flag("-size"), flag("-mtime"), flag("-newer"),
        flag("-maxdepth"), flag("-mindepth"),
        flag("-print"), flag("-print0"), flag("-f"),
    ],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="grep",
    system_path=["/usr/bin/grep", "/bin/grep"],
    options=[
        flag("-r"), flag("-R"), flag("-i"), flag("-n"), flag("-l"),
        flag("-c"), flag("-v"), flag("-E"), flag("-F"), flag("-e"), flag("-f"),
        flag("--exclude-dir"), flag("--include"), flag("--exclude"),
        flag("--color"), flag("-h"), flag("-H"), flag("-I"),
    ],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="cp",
    system_path=["/usr/bin/cp", "/bin/cp"],
    options=[
        flag("-r"),
        flag("-R"),
        flag("--recursive"),
    ],
    args=[ARG_RFILE, ARG_WFILE],
)

define_program(
    program="mkdir",
    system_path=["/usr/bin/mkdir", "/bin/mkdir"],
    options=[
        flag("-p"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="bun",
    system_path=["/usr/bin/bun"],
    options=[
        flag("--noEmit"),
    ],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="bunx",
    system_path=["/usr/bin/bunx"],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="node",
    system_path=["/usr/bin/node", "/usr/local/bin/node"],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="sed",
    system_path=["/usr/bin/sed", "/bin/sed"],
    options=[
        flag("-n"),
        flag("-i"),
        flag("-e"),
        flag("-f"),
        flag("-r"),
        flag("-E"),
        flag("-z"),
        flag("-l"),
        flag("-s"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="sh",
    system_path=["/usr/bin/sh", "/bin/sh"],
    args=[ARG_OPAQUE_VALUE],
    forbidden="sh is allowed as a bwrap entry point only; injection patterns are caught by pre-filter",
)

forbid_substrings([
    "/dev/tcp",
    "/dev/udp",
])

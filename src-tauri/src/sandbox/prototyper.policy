"""
Prototyper execution policy for agcodex-execpolicy.
Allows safe development tools commonly used in UI prototyping.
Note: define_program, flag, opt, ARG_* are built-in globals — no load() needed.
"""

define_program(
    program="ls",
    system_path=["/usr/bin/ls", "/bin/ls"],
    options=[
        flag("-a"),
        flag("-l"),
        flag("-1"),
        flag("-R"),
    ],
    args=[ARG_RFILES],
)

define_program(
    program="cat",
    system_path=["/usr/bin/cat", "/bin/cat"],
    options=[
        flag("-n"),
        flag("-b"),
    ],
    args=[ARG_RFILES],
)

define_program(
    program="head",
    system_path=["/usr/bin/head", "/bin/head"],
    options=[
        opt("-n", ARG_OPAQUE_VALUE),
    ],
    args=[ARG_RFILES],
)

define_program(
    program="find",
    system_path=["/usr/bin/find", "/bin/find"],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="cp",
    system_path=["/usr/bin/cp", "/bin/cp"],
    options=[
        flag("-r"),
        flag("-R"),
        flag("--recursive"),
    ],
    args=[ARG_RFILE, ARG_WFILE],
)

define_program(
    program="mkdir",
    system_path=["/usr/bin/mkdir", "/bin/mkdir"],
    options=[
        flag("-p"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="bun",
    system_path=["/usr/bin/bun"],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="bunx",
    system_path=["/usr/bin/bunx"],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="node",
    system_path=["/usr/bin/node", "/usr/local/bin/node"],
    args=[ARG_UNVERIFIED_VARARGS],
)

define_program(
    program="sed",
    system_path=["/usr/bin/sed", "/bin/sed"],
    options=[
        flag("-i"),
        flag("-n"),
        flag("-E"),
        flag("-r"),
    ],
    args=[ARG_OPAQUE_VALUE],
)

define_program(
    program="sh",
    system_path=["/usr/bin/sh", "/bin/sh"],
    args=[ARG_OPAQUE_VALUE],
    forbidden="sh is allowed as a bwrap entry point only; injection patterns are caught by pre-filter",
)

forbid_substrings([
    "/dev/tcp",
    "/dev/udp",
])
